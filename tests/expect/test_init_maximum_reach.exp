#!/usr/bin/expect -f
# Test: bincast init with Maximum Reach profile (option 1)
# All channels enabled — needs npm scope, tap repo, bucket repo

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "1\r"

# npm scope
expect "npm scope"
send "@testorg\r"

# Homebrew tap (accept default)
expect "Homebrew tap"
send "\r"

# Scoop bucket (accept default)
expect "Scoop bucket"
send "\r"

# Targets
expect "enter"
send "\r"

expect "Created releaser.toml"
expect eof

# Assert
set fp [open "releaser.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }
if {![has $content "\[distribute.pypi\]"]} { puts "FAIL: pypi missing"; exit 1 }
if {![has $content "\[distribute.npm\]"]} { puts "FAIL: npm missing"; exit 1 }
if {![has $content "@testorg"]} { puts "FAIL: npm scope missing"; exit 1 }
if {![has $content "\[distribute.homebrew\]"]} { puts "FAIL: homebrew missing"; exit 1 }
if {![has $content "\[distribute.scoop\]"]} { puts "FAIL: scoop missing"; exit 1 }
if {![has $content "\[distribute.cargo\]"]} { puts "FAIL: cargo missing"; exit 1 }
if {![has $content "\[distribute.install_script\]"]} { puts "FAIL: install_script missing"; exit 1 }

puts "ALL PASS: maximum reach profile"
exit 0
