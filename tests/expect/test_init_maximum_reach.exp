#!/usr/bin/expect -f
# Test: Maximum Reach profile (option 1) — all channels

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "1\r"

expect "npm scope"
send "@testorg\r"
expect "Homebrew tap"
send "\r"
send "\r"

expect "Execute"
send "\r"

expect "Done!"
expect eof

set fp [open "bincast.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }
if {![has $content "\[distribute.pypi\]"]} { puts "FAIL: pypi missing"; exit 1 }
if {![has $content "\[distribute.npm\]"]} { puts "FAIL: npm missing"; exit 1 }
if {![has $content "@testorg"]} { puts "FAIL: npm scope missing"; exit 1 }
if {![has $content "\[distribute.homebrew\]"]} { puts "FAIL: homebrew missing"; exit 1 }
if {![has $content "\[distribute.cargo\]"]} { puts "FAIL: cargo missing"; exit 1 }

puts "ALL PASS: maximum reach profile"
exit 0
