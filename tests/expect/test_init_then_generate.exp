#!/usr/bin/expect -f
# Test: Full scenario — init with Rust Ecosystem, then generate, verify files on disk

set timeout 15
set bincast [lindex $argv 0]

# Step 1: Init
spawn $bincast init
expect "Choose"
send "2\r"
expect "enter"
send "\r"
expect "Created releaser.toml"
expect eof

# Verify releaser.toml exists
if {![file exists "releaser.toml"]} { puts "FAIL: releaser.toml not created"; exit 1 }
puts "OK: releaser.toml created"

# Step 2: Generate
spawn $bincast generate
expect {
    "Generated" {}
    timeout { puts "FAIL: generate did not complete"; exit 1 }
}
expect eof

# Step 3: Verify all expected files on disk
set expected_files {
    ".github/workflows/release.yml"
    "install.sh"
    "install.ps1"
    "binstall.toml"
}

foreach f $expected_files {
    if {![file exists $f]} {
        puts "FAIL: expected file missing: $f"
        exit 1
    }
    # Verify non-empty
    set size [file size $f]
    if {$size == 0} {
        puts "FAIL: file is empty: $f"
        exit 1
    }
    puts "OK: $f exists (${size} bytes)"
}

# Step 4: Verify CI workflow content
set fp [open ".github/workflows/release.yml" r]
set ci [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $ci "cargo build --release"]} { puts "FAIL: CI missing cargo build"; exit 1 }
if {![has $ci "test-tool"]} { puts "FAIL: CI missing project name"; exit 1 }
if {![has $ci "aarch64-apple-darwin"]} { puts "FAIL: CI missing ARM darwin target"; exit 1 }
if {![has $ci "x86_64-pc-windows-msvc"]} { puts "FAIL: CI missing windows target"; exit 1 }
if {![has $ci "SHA-256"]} { puts "FAIL: CI missing checksum step"; exit 1 }

# Step 5: Verify install.sh content
set fp [open "install.sh" r]
set sh [read $fp]
close $fp

if {![has $sh "#!/bin/sh"]} { puts "FAIL: install.sh missing shebang"; exit 1 }
if {![has $sh "test-tool"]} { puts "FAIL: install.sh missing project name"; exit 1 }
if {![has $sh "user/test-tool"]} { puts "FAIL: install.sh missing repo"; exit 1 }

# Step 6: Verify releaser.toml has no PyPI (Rust Ecosystem = no PyPI)
set fp [open "releaser.toml" r]
set toml [read $fp]
close $fp

if {[has $toml "\[distribute.pypi\]"]} { puts "FAIL: Rust Ecosystem should not have PyPI"; exit 1 }
if {![has $toml "\[distribute.cargo\]"]} { puts "FAIL: Rust Ecosystem should have cargo"; exit 1 }

puts "ALL PASS: init → generate → verify files on disk"
exit 0
