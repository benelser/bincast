#!/usr/bin/expect -f
# Test: Full scenario — init (Rust Ecosystem) then verify generated files on disk

set timeout 15
set bincast [lindex $argv 0]

# Step 1: Init
spawn $bincast init
expect "Choose"
send "2\r"
expect "Execute"
send "\r"
expect "Done!"
expect eof

if {![file exists "bincast.toml"]} { puts "FAIL: bincast.toml missing"; exit 1 }

# Step 2: Verify generated files exist (init now generates them automatically)
set expected_files {
    ".github/workflows/release.yml"
    "install.sh"
    "install.ps1"
}

foreach f $expected_files {
    if {![file exists $f]} {
        puts "FAIL: expected file missing: $f"
        exit 1
    }
    set size [file size $f]
    if {$size == 0} {
        puts "FAIL: file is empty: $f"
        exit 1
    }
    puts "OK: $f exists (${size} bytes)"
}

# Step 3: Verify CI content
set fp [open ".github/workflows/release.yml" r]
set ci [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $ci "cargo build --release"]} { puts "FAIL: CI missing cargo build"; exit 1 }
if {![has $ci "test-tool"]} { puts "FAIL: CI missing project name"; exit 1 }

puts "ALL PASS: init → generated files on disk"
exit 0
