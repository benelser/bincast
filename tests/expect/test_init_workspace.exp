#!/usr/bin/expect -f
# Test: Workspace detection

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init

expect {
    "Detected workspace" { puts "OK: workspace detected" }
    "Detected:" { puts "OK: detected" }
    timeout { puts "FAIL: no detection"; exit 1 }
}

expect "Choose"
send "3\r"

expect "Execute"
send "\r"

expect "Done!"
expect eof

set fp [open "releaser.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "my-cli"]} { puts "FAIL: binary name missing"; exit 1 }
if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }

puts "ALL PASS: workspace init"
exit 0
