#!/usr/bin/expect -f
# Test: bincast init with Minimal profile (option 3)
# AAA: Arrange (fixture) → Act (run init) → Assert (check TOML)

set timeout 10
set bincast [lindex $argv 0]

# Act
spawn $bincast init
expect "Choose"
send "3\r"
expect "enter"
send "\r"
expect "Created releaser.toml"
expect eof

# Assert
set fp [open "releaser.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }
if {![has $content "\[distribute.install_script\]"]} { puts "FAIL: install_script missing"; exit 1 }
if {[has $content "\[distribute.pypi\]"]} { puts "FAIL: pypi should not be in minimal"; exit 1 }
if {[has $content "\[distribute.npm\]"]} { puts "FAIL: npm should not be in minimal"; exit 1 }
if {[has $content "\[distribute.homebrew\]"]} { puts "FAIL: homebrew should not be in minimal"; exit 1 }

puts "ALL PASS: minimal profile"
exit 0
