#!/usr/bin/expect -f
# Test: bincast init with Minimal profile (option 3)

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "3\r"

# Confirm execution
expect "Execute"
send "\r"

expect "Done!"
expect eof

# Assert
set fp [open "releaser.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }
if {![has $content "\[distribute.install_script\]"]} { puts "FAIL: install_script missing"; exit 1 }
if {[has $content "\[distribute.pypi\]"]} { puts "FAIL: pypi present in minimal"; exit 1 }
if {[has $content "\[distribute.npm\]"]} { puts "FAIL: npm present in minimal"; exit 1 }

puts "ALL PASS: minimal profile"
exit 0
