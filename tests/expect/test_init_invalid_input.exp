#!/usr/bin/expect -f
# Test: Invalid profile choice → graceful default

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "7\r"

expect "Execute"
send "\r"

expect "Done!"
expect eof

set fp [open "bincast.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }

puts "ALL PASS: invalid input handled"
exit 0
