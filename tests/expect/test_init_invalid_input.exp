#!/usr/bin/expect -f
# Test: bincast init with invalid input — should use defaults gracefully

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "7\r"

# Invalid choice → should use default (3 = Minimal)
expect "enter"
send "\r"

expect "Created releaser.toml"
expect eof

# Assert: should have used the default profile
set fp [open "releaser.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.github\]"]} { puts "FAIL: github missing"; exit 1 }
if {![has $content "\[distribute.install_script\]"]} { puts "FAIL: install_script missing after default"; exit 1 }

puts "ALL PASS: invalid input handled gracefully"
exit 0
