#!/usr/bin/expect -f
# Test: Custom profile (option 4) — selective channels

set timeout 10
set bincast [lindex $argv 0]

spawn $bincast init
expect "Choose"
send "4\r"

expect "Install scripts"
send "\r"
expect "PyPI"
send "n\r"
expect "npm"
send "y\r"
expect "npm scope"
send "@myorg\r"
expect "Homebrew"
send "y\r"
expect "tap repo"
send "\r"
expect "Scoop"
send "n\r"
expect "crates.io"
send "y\r"

expect "Execute"
send "\r"

expect "Done!"
expect eof

set fp [open "bincast.toml" r]
set content [read $fp]
close $fp

proc has {content text} { return [expr {[string first $text $content] >= 0}] }

if {![has $content "\[distribute.npm\]"]} { puts "FAIL: npm missing"; exit 1 }
if {![has $content "@myorg"]} { puts "FAIL: npm scope missing"; exit 1 }
if {![has $content "\[distribute.homebrew\]"]} { puts "FAIL: homebrew missing"; exit 1 }
if {![has $content "\[distribute.cargo\]"]} { puts "FAIL: cargo missing"; exit 1 }
if {[has $content "\[distribute.pypi\]"]} { puts "FAIL: pypi present"; exit 1 }
if {[has $content "\[distribute.scoop\]"]} { puts "FAIL: scoop present"; exit 1 }

puts "ALL PASS: custom profile"
exit 0
